{
  "name": "nextjs-template",
  "version": "0.1.0",
  "private": true,
  "author": "Tanmay Mundra",
  "scripts": {
    "dev": "next dev",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,mdx,css,html,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,mdx,css,html,yml,yaml}\"",
    "type-check": "tsc --noEmit",
    "theme:generate": "tsx scripts/generate-css-vars.js",
    "generate:types": "bash docs/scripts/generate-api-types.sh",
    "dev:with-sync": "npm run generate:types && npm run dev",
    "prebuild": "node -e \"try{require('child_process').execSync('pnpm run generate:types',{stdio:'inherit'})}catch(e){process.exit(0)}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-list": "^2.4.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.37.0",
    "libphonenumber-js": "^1.12.38",
    "lucide-react": "^0.562.0",
    "next": "^15.5.9",
    "pnpm": "^10.32.1",
    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/country-list": "^2.1.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.12",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.10",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typedoc": "^0.28.17",
    "typescript": "^5"
  }
}
